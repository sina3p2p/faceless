# Database
DATABASE_URL="postgresql://user:password@localhost:5432/faceless?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OpenRouter (LLM) — model is configured per-series in the UI
OPENROUTER_API_KEY=""

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=""
ELEVENLABS_DEFAULT_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# OpenAI (Image Generation fallback + Whisper for music alignment)
OPENAI_API_KEY=""

# AI video — pick models in the UI; configure the providers you use
RUNWAYML_API_SECRET=""
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
# Optional override (default: https://api-singapore.klingai.com)
# KLING_API_BASE=""

# Google Gemini API (Veo image-to-video)
GOOGLE_GENAI_API_KEY=""

# xAI (Grok Imagine video)
XAI_API_KEY=""

# ByteDance Seed / BytePlus ModelArk (Seedance 2, etc.) — https://seed.bytedance.com/
BYTEPLUS_ARK_API_KEY=""
# Optional; default is ap-southeast data plane (see ModelArk “Base URL and authentication”)
# BYTEPLUS_ARK_BASE_URL="https://ark.ap-southeast.bytepluses.com/api/v3"

# Suno (AI Music Generation — optional, for Music Video mode)
SUNO_API_KEY=""

# S3-Compatible Storage (Cloudflare R2, AWS S3, etc.)
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="faceless-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# R2 public access URL (optional, skips signed URLs if set)
# Enable public access on your R2 bucket, then paste the URL here
R2_PUBLIC_URL=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_STARTER=""
STRIPE_PRICE_ID_PRO=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"